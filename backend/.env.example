# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/notesmanager

# JWT Configuration
# Use a strong random secret (at least 32 characters)
JWT_SECRET=notesManagerSecretKey123456789012345678901234567890
JWT_EXPIRATION=86400000

# CORS allowed origins (comma-separated)
# For production, add your Vercel frontend URL, e.g.: https://notes-manager.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# Server port
SERVER_PORT=8080